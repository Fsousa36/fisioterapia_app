{
  "name": "fisiobase-academy",
  "private": true,
  "version": "0.1.0",
  "description": "FisioBase Academy monorepo: Expo mobile, Next.js web/admin and NestJS API.",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,yml,yaml,css}\"",
    "db:generate": "pnpm --filter @fisiobase/database db:generate",
    "db:migrate": "pnpm --filter @fisiobase/database db:migrate",
    "db:seed": "pnpm --filter @fisiobase/database db:seed",
    "db:studio": "pnpm --filter @fisiobase/database db:studio",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
