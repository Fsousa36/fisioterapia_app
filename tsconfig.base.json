{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "forceConsistentCasingInFileNames": true,
    "baseUrl": ".",
    "paths": {
      "@fisiobase/types": ["packages/types/src/index.ts"],
      "@fisiobase/types/*": ["packages/types/src/*"],
      "@fisiobase/config/*": ["packages/config/*"]
    }
  }
}
